# Normalisation des fins de ligne
* text=auto

# TypeScript / JavaScript — LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf

# Binaires
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
