# ================================================================
# RGNC WebMap — Variables d'environnement Frontend
# Copier en .env.local pour le développement
# Sur Vercel : renseigner dans Project Settings > Environment Variables
# ================================================================

# URL de base de l'API Django (sans slash final)
# Développement local :
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Démo Railway (remplacer par votre URL Railway après déploiement) :
# NEXT_PUBLIC_API_URL=https://votre-app.up.railway.app/api

# Nom de domaine du backend pour Next/Image (photos de bornes)
# Laisser vide en local. En production : hostname sans https://
# NEXT_PUBLIC_BACKEND_HOSTNAME=votre-app.up.railway.app

NEXT_PUBLIC_APP_NAME=RGNC WebMap
NEXT_PUBLIC_APP_VERSION=1.0.0
